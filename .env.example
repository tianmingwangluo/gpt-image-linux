DEFAULT_API_URL=
DEFAULT_API_KEY=
DEFAULT_API_PATH=/v1/images/generations
DEFAULT_RESPONSES_MODEL=gpt-5.4
APP_VERSION=
GITHUB_REPO=Z1rconium/gpt-image-linux
ACCESS_KEY=
ALLOW_UNAUTHENTICATED=false
IP_ALLOWLIST=
TRUST_PROXY_HEADERS=false
MAX_FILE_SIZE_MB=50

# Import archive limits
# Maximum uploaded ZIP size in MB. Recommended: keep this comfortably above MAX_FILE_SIZE_MB.
IMPORT_ARCHIVE_MAX_MB=1000
# Maximum number of files allowed inside one import archive.
IMPORT_MAX_FILES=500
# Maximum total uncompressed archive size in MB after extraction.
IMPORT_MAX_UNCOMPRESSED_MB=1024
# Maximum metadata.json size in bytes.
IMPORT_MAX_METADATA_BYTES=2097152
# Maximum allowed uncompressed/compressed ratio to reduce zip bomb risk.
IMPORT_MAX_COMPRESSION_RATIO=100

# Background job limits
# Maximum number of generation/edit jobs running at the same time.
MAX_ACTIVE_GENERATE_JOBS=2
# Maximum number of additional queued generation/edit jobs.
MAX_QUEUED_GENERATE_JOBS=20

PYTHON_BASE_IMAGE=python:3.11-slim

# Security settings
ACCESS_COOKIE_SECURE=true
ACCESS_MAX_FAILURES=5
ACCESS_LOCKOUT_SECONDS=300
UPSTREAM_HOST_ALLOWLIST=
WEBHOOK_HOST_ALLOWLIST=
WEBHOOK_SIGNING_SECRET=
WEBHOOK_TIMEOUT_SECONDS=5
WEBHOOK_MAX_ATTEMPTS=3
